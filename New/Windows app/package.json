{
  "name": "quark",
  "version": "0.0.5-beta01c",
  "description": "game launcher for Windows",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "next:build": "cd ../web/act-l && npm run build",
    "build": "npm run next:build && electron-builder",
    "pack": "npm run next:build && electron-builder --dir",
    "release": "npm run next:build && electron-builder --publish always"
  },
  "author": "c14b7",
  "license": "MIT",
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^25.0.0",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.quark.launcher",
    "productName": "Quark Launcher",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "c14b7",
        "repo": "Quark-Launcher"
      }
    ],
    "files": [
      "main.js",
      "dev-server.js",
      "preload.js",
      "overlay-manager.js",
      "overlay.html",
      "overlay.css",
      "overlay-renderer.js",
      "overlay-preload.js",
      "overlay-performance.js",
      "dev-app-update.yml",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../web/act-l/out",
        "to": "app",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
