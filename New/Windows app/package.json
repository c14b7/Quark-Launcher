{
  "name": "quark",
  "version": "0.0.5-beta01",
  "description": "game launcher for Windows",
  "main": "main.js",              
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run next:dev\" \"wait-on http://localhost:30211 && electron .\"",
    "next:dev": "cd ../web/act-l && npm run dev -- -p 30211",
    "next:build": "cd ../web/act-l && npm run build",
    "build": "npm run next:build && electron-builder",
    "pack": "npm run next:build && electron-builder --dir",
    "release": "npm run next:build && electron-builder --publish always"
  },              
  "author": "c14b7",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^39.8.5",
    "electron-builder": "^25.0.0",
    "electron-packager": "^17.1.2",
    "wait-on": "^7.2.0"
  },
"build": {
    "appId": "com.quark.launcher",
    "productName": "Quark Launcher",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "c14b7",
        "repo": "Quark-Launcher"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "dev-app-update.yml",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../web/act-l/out",
        "to": "app",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
