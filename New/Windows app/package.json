{
  "name": "quark",
  "version": "0.0.3 beta 04a",
  "description": "game launcher for Windows",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run next:dev\" \"wait-on http://localhost:30211 && electron .\"",
    "next:dev": "cd ../web/act-l && npm run dev -- -p 30211",
    "next:build": "cd ../web/act-l && npm run build",
    "build": "npm run next:build && electron-builder",
    "pack": "npm run next:build && electron-builder --dir"
  },
  "author": "c14b7",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-packager": "^17.1.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.quark.launcher",
    "productName": "Quark Launcher",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../web/act-l/out",
        "to": "app",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    }
  }
}
